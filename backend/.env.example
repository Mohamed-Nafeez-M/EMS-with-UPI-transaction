PORT=5000
DATABASE_URL=postgresql://postgres:password@localhost:5432/ems_db
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
NODE_ENV=development

# ── Email (optional) ──────────────────────────────────────────────────────────
# Leave these blank to run in test mode (emails are logged to console only).
# Fill them in to send real emails via Gmail (or change the service in sendEmail.js).
# For Gmail: use an App Password, not your regular password.
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_USER=
EMAIL_PASS=
